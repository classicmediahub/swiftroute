# Set this to your deployed Netlify URL once you have it, e.g:
# ALLOWED_ORIGIN=https://swiftroute.netlify.app
ALLOWED_ORIGIN=
# Local dev: install Postgres and point at it, e.g:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/swiftroute
