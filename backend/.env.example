PORT=4000
JWT_SECRET=pickandearn_dev_secret_change_in_production_9f3a7c1e
ADMIN_INVITE_CODE=SWIFTROUTE-ADMIN-2026
# Set this to your deployed Netlify URL once you have it, e.g:
# ALLOWED_ORIGIN=https://pickandearn.vercel.app
ALLOWED_ORIGIN=
# Local dev: install Postgres and point at it, e.g:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/swiftroute
# Render: use the "Internal Database URL" Render gives you when you create
# a Postgres instance, and paste it here as-is.
DATABASE_URL=
# From your Paystack dashboard: Settings > API Keys & Webhooks.
# Use a "sk_test_..." key while developing, "sk_live_..." once you're ready
# to accept real payments.
PAYSTACK_SECRET_KEY=
# Where Paystack should redirect customers back to after checkout.
# Local dev: http://localhost:5173
# Production: your Vercel URL, e.g. https://pickandearn.vercel.app
FRONTEND_URL=http://localhost:5173
# Email notifications via Resend: sign up at resend.com, then
# Settings > API Keys. RESEND_FROM_EMAIL must use a domain you've verified
# in Resend once you're ready for production — the resend.dev sender only
# works for testing and only delivers to your own account email.
RESEND_API_KEY=
RESEND_FROM_EMAIL=SwiftRoute <onboarding@resend.dev>
# SMS notifications via Termii: sign up at termii.com, dashboard > API Keys.
# TERMII_SENDER_ID must be a Sender ID registered and approved in your
# Termii account — using an unapproved one will cause sends to fail.
TERMII_API_KEY=
TERMII_SENDER_ID=Termii
# Real distance-based pricing via Mapbox: sign up at mapbox.com (a card is
# required to activate the free tier, but you won't be charged within the
# free monthly allowance — 100,000 geocoding lookups + 100,000 route
# calculations per month). Get your token at Account > Tokens > default
# public token, or create a new one.
# If this is left blank, pricing automatically falls back to the older
# flat same-city/intercity estimate instead of breaking.
MAPBOX_ACCESS_TOKEN=
